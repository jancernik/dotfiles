        accel_profile = "flat",
    },
})

hl.curve("easeOutQuint",   { type = "bezier", points = { {0.22, 1},   {0.36, 1}   } })
hl.curve("easeOutCubic",   { type = "bezier", points = { {0.33, 1},   {0.68, 1}   } })
hl.curve("easeOutQuad",    { type = "bezier", points = { {0.5, 1},    {0.89, 1}   } })
hl.curve("easeInOutCirc",  { type = "bezier", points = { {0.85, 0},   {0.15, 1}   } })
hl.curve("easeInOutQuart", { type = "bezier", points = { {0.76, 0},   {0.24, 1}   } })
hl.curve("easeInOutCubic", { type = "bezier", points = { {0.65, 0},   {0.35, 1}   } })
hl.curve("easeInQuint",    { type = "bezier", points = { {0.64, 0},   {0.78, 0}   } })
hl.curve("linear",         { type = "bezier", points = { {0, 0},      {1, 1}      } })
hl.curve("almostLinear",   { type = "bezier", points = { {0.5, 0.5},  {0.75, 1}   } })
hl.curve("quick",          { type = "bezier", points = { {0.15, 0},   {0.1, 1}    } })

hl.animation({ leaf = "global",        enabled = true, speed = 10,   bezier = "almostLinear" })
hl.animation({ leaf = "border",        enabled = true, speed = 5.39, bezier = "easeOutQuint" })
hl.animation({ leaf = "windows",       enabled = true, speed = 4.79, bezier = "easeOutQuint" })
hl.animation({ leaf = "windowsIn",     enabled = true, speed = 4.1,  bezier = "easeOutQuint",  style = "popin 87%" })
hl.animation({ leaf = "windowsOut",    enabled = true, speed = 1.49, bezier = "linear",        style = "popin 87%" })
hl.animation({ leaf = "fadeIn",        enabled = true, speed = 1.73, bezier = "almostLinear" })
hl.animation({ leaf = "fadeOut",       enabled = true, speed = 1.46, bezier = "almostLinear" })
hl.animation({ leaf = "fade",          enabled = true, speed = 3.03, bezier = "quick" })
hl.animation({ leaf = "layers",        enabled = true, speed = 3.81, bezier = "easeOutQuint" })
hl.animation({ leaf = "layersIn",      enabled = true, speed = 5,    bezier = "easeOutQuint",  style = "fade" })
hl.animation({ leaf = "layersOut",     enabled = true, speed = 3,    bezier = "easeInOutCirc", style = "fade" })
hl.animation({ leaf = "fadeLayersIn",  enabled = true, speed = 3,    bezier = "easeOutQuint" })
hl.animation({ leaf = "fadeLayersOut", enabled = true, speed = 3,    bezier = "easeInQuint" })
hl.animation({ leaf = "workspaces",    enabled = true, speed = 3,    bezier = "easeInOutCubic", style = "slidevert" })
hl.animation({ leaf = "zoomFactor",    enabled = true, speed = 7,    bezier = "quick" })

