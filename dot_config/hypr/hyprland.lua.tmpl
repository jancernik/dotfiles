package.path = package.path .. ";/home/jan/plugins/split-monitor-workspaces/lua/?.lua"
smw = require("split-monitor-workspaces")

smw.setup({
    workspace_count = 5,
    keep_focused = true,
    enable_notifications = false,
    enable_persistent_workspaces = true,
    enable_wrapping = false,
{{- if eq .chezmoi.hostname "arch-desktop" }}
    monitor_priority = {"DP-1", "DP-2", "DP-3"},
{{- end }}
})

