local mainMod = "SUPER"
local mainModShift = "SUPER + SHIFT"

hl.bind(mainMod .. " + Return", hl.dsp.exec_cmd(Terminal))
hl.bind(mainModShift .. " + Return", hl.dsp.exec_cmd(EphemeralTerminal))
hl.bind(mainMod .. " + Space", hl.dsp.exec_cmd(Menu))
hl.bind(mainMod .. " + E", hl.dsp.exec_cmd(Files))
hl.bind(mainMod .. " + W", hl.dsp.exec_cmd(Browser))
hl.bind(mainMod .. " + O", hl.dsp.exec_cmd(Obsidian))
hl.bind(mainMod .. " + I", hl.dsp.exec_cmd("hyprpicker --autocopy"))
hl.bind(mainModShift .. " + W", hl.dsp.exec_cmd(Whatsapp))
hl.bind(mainModShift .. " + L", hl.dsp.exec_cmd("bash -c 'hyprctl dispatch \"hl.dsp.focus({ monitor = \\\"" .. MainMonitor .. "\\\" })\"; pidof gtklock || gtklock -d -f'"))
hl.bind(mainMod .. " + V", hl.dsp.exec_cmd(Clipboard))
hl.bind(mainMod .. " + code:60", hl.dsp.exec_cmd(Emojis))
hl.bind(mainMod .. " + code:49", hl.dsp.exec_cmd("~/.scripts/monitor-backlight.sh"))
hl.bind(mainModShift .. " + R", hl.dsp.exec_cmd("bash -c ' { echo === Reload $(date) ===; ~/.scripts/autoreload.sh; killall -w gjs; ~/minishell/run.sh; } >> /tmp/minishell.log 2>&1'"))
hl.bind(mainMod .. " + F", hl.dsp.window.fullscreen())
hl.bind(mainMod .. " + Q", hl.dsp.window.close())
hl.bind(mainMod .. " + R", hl.dsp.window.float())
hl.bind(mainMod .. " + P", hl.dsp.window.pseudo())
hl.bind(mainMod .. " + D", hl.dsp.layout("togglesplit"))
hl.bind(mainModShift .. " + M", hl.dsp.exit())

hl.bind("Escape", hl.dsp.exec_cmd([=[bash -c '[[ $(hyprctl activewindow -j | jq -r ".class") == "ephemeral-kitty" ]] && pypr hide ephemeral-kitty']=]), { non_consuming = true })

hl.bind("switch:on:Lid Switch", hl.dsp.exec_cmd("bash -c 'pidof gtklock >/dev/null || gtklock -d -f; systemctl suspend'"), { locked = true })

hl.bind("XF86AudioRaiseVolume", hl.dsp.exec_cmd("wpctl set-mute @DEFAULT_SINK@ 0; wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+"), { locked = true, repeating = true })
hl.bind("XF86AudioLowerVolume", hl.dsp.exec_cmd("wpctl set-mute @DEFAULT_SINK@ 0; wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"), { locked = true, repeating = true })
hl.bind("XF86AudioMute", hl.dsp.exec_cmd("wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"), { locked = true, repeating = true })
hl.bind("XF86AudioMicMute", hl.dsp.exec_cmd("wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"), { locked = true, repeating = true })

hl.bind("XF86Explorer", hl.dsp.exec_cmd("~/.scripts/brightness.sh -5"), { locked = true, repeating = true }) -- F1 Feker IK75
hl.bind("XF86HomePage", hl.dsp.exec_cmd("~/.scripts/brightness.sh +5"), { locked = true, repeating = true }) -- F2 Feker IK75
hl.bind("XF86MonBrightnessDown", hl.dsp.exec_cmd("~/.scripts/brightness.sh -5"), { locked = true, repeating = true })
hl.bind("XF86MonBrightnessUp", hl.dsp.exec_cmd("~/.scripts/brightness.sh +5"), { locked = true, repeating = true })

hl.bind("XF86AudioNext", hl.dsp.exec_cmd("playerctl next"), { locked = true })
hl.bind("XF86AudioPause", hl.dsp.exec_cmd("playerctl play-pause"), { locked = true })
hl.bind("XF86AudioPlay", hl.dsp.exec_cmd("playerctl play-pause"), { locked = true })
hl.bind("XF86AudioPrev", hl.dsp.exec_cmd("playerctl previous"), { locked = true })

hl.bind("PRINT", hl.dsp.exec_cmd("hyprshot -m region"))
hl.bind("CTRL + PRINT", hl.dsp.exec_cmd("hyprshot -m output"))
hl.bind("SHIFT + PRINT", hl.dsp.exec_cmd("hyprshot -m window"))

hl.bind("insert", hl.dsp.exec_cmd(""))

hl.bind(mainMod .. " + T", hl.dsp.exec_cmd("~/.scripts/toggle-dashboard.sh"))

hl.bind(mainMod .. " + S", hl.dsp.workspace.toggle_special("home-assistant"))
hl.bind("mouse:275", hl.dsp.workspace.toggle_special("home-assistant"), { release = true })

-- Workspaces
for i = 1, smw.get_amount_of_workspaces() do
  local n = tostring(i)
  hl.bind(mainMod .. " +" .. n, smw.workspace(n))
  hl.bind(mainMod .. " + SHIFT +" .. n, smw.move_to_workspace_silent(n))
end

hl.bind(mainMod .. " + mouse_down", smw.cycle_workspaces("prev"))
hl.bind(mainMod .. " + mouse_up", smw.cycle_workspaces("next"))

hl.gesture({ fingers = 3, direction = "down", action = function() hl.dispatch(smw.cycle_workspaces("prev")) end })
hl.gesture({ fingers = 3, direction = "up", action = function() hl.dispatch(smw.cycle_workspaces("next")) end })

-- Windows
hl.bind(mainMod .. " + left", hl.dsp.focus({ direction = "left" }))
hl.bind(mainMod .. " + right", hl.dsp.focus({ direction = "right" }))
hl.bind(mainMod .. " + up", hl.dsp.focus({ direction = "up" }))
hl.bind(mainMod .. " + down", hl.dsp.focus({ direction = "down" }))

hl.bind(mainMod .. " + mouse:272", hl.dsp.window.drag(), { mouse = true })
hl.bind(mainMod .. " + mouse:273", hl.dsp.window.resize(), { mouse = true })

hl.bind(mainMod .. " + ALT + left", hl.dsp.window.resize({ x = -100, y = 0, relative = true }), { repeating = true })
hl.bind(mainMod .. " + ALT + right", hl.dsp.window.resize({ x = 100, y = 0, relative = true }), { repeating = true })
hl.bind(mainMod .. " + ALT + up", hl.dsp.window.resize({ x = 0, y = -100, relative = true }), { repeating = true })
hl.bind(mainMod .. " + ALT + down", hl.dsp.window.resize({ x = 0, y = 100, relative = true }), { repeating = true })

hl.bind(mainMod .. " + SHIFT + left", hl.dsp.window.move({ direction = "left" }))
hl.bind(mainMod .. " + SHIFT + right", hl.dsp.window.move({ direction = "right" }))
hl.bind(mainMod .. " + SHIFT + up", hl.dsp.window.move({ direction = "up" }))
hl.bind(mainMod .. " + SHIFT + down", hl.dsp.window.move({ direction = "down" }))

hl.bind(mainMod .. " + CTRL + left", hl.dsp.window.swap({ direction = "left" }))
hl.bind(mainMod .. " + CTRL + right", hl.dsp.window.swap({ direction = "right" }))
hl.bind(mainMod .. " + CTRL + up", hl.dsp.window.swap({ direction = "up" }))
hl.bind(mainMod .. " + CTRL + down", hl.dsp.window.swap({ direction = "down" }))

{{ if eq .chezmoi.hostname "arch-laptop" -}}
hl.bind("XF86TouchpadToggle", hl.dsp.exec_cmd([[bash -c '
state_file=/tmp/touchpad-enabled

if [ "$(cat "$state_file" 2>/dev/null)" = "false" ]; then
  hyprctl eval "hl.device({ name = \"asue140d:00-04f3:31b9-touchpad\", enabled = true })"
  echo true > "$state_file"
else
  hyprctl eval "hl.device({ name = \"asue140d:00-04f3:31b9-touchpad\", enabled = false })"
  echo false > "$state_file"
fi
']]))
{{- end -}}
