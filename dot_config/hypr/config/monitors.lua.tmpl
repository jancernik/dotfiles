{{- if eq .chezmoi.hostname "arch-desktop" -}}
hl.monitor({
  output = "DP-1",
  mode = "2560x1440@144",
  position = "0x0",
  scale = 1,
})
hl.monitor({
  output = "DP-2",
  mode = "2560x1440@144",
  position = "2560x0",
  scale = 1,
})
hl.monitor({
  output = "DP-3",
  mode = "2560x1440@144",
  position = "5120x0",
  scale = 1,
})
hl.monitor({
  output = "",
  mode = "preferred",
  position = "auto",
  scale = 1,
})
{{- else if eq .chezmoi.hostname "arch-laptop" -}}
hl.monitor({
  output = "eDP-1",
  mode = "2880x1800@120",
  position = "0x0",
  scale = 1.8,
})
hl.monitor({
  output = "",
  mode = "preferred",
  position = "auto",
  scale = 1,
})
{{- else -}}
hl.monitor({
  output = "",
  mode = "preferred",
  position = "auto",
  scale = 1,
})
{{- end -}}
